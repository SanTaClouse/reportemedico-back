TZ="America/Santo_Domingo"
DATABASE_URL="postgresql://rmuser:password@localhost:5432/reportemedico"
JWT_SECRET="cambiar-en-produccion-string-largo-y-aleatorio"
JWT_EXPIRES_IN="7d"
PORT=3001
CORS_ORIGIN="http://localhost:3000"

# Cloudinary (cuenta del cliente)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Seed — REQUERIDO antes de correr npm run prisma:seed
# Mínimo 12 caracteres. Usar un generador de passwords en producción.
ADMIN_INITIAL_PASSWORD=""
ADMIN_INITIAL_EMAIL="admin@reportemedico.com"

# Email (Brevo SMTP — plan gratuito: 300 emails/día)
# Credenciales en https://app.brevo.com → SMTP & API → pestaña SMTP
SMTP_HOST="smtp-relay.brevo.com"      # fijo para Brevo
SMTP_PORT=587                          # 587 STARTTLS (recomendado)
SMTP_USER=""                           # el "Login" que muestra Brevo (un código xxxxx@smtp-brevo.com)
SMTP_PASS=""                           # la "SMTP key" generada (NO la contraseña de la cuenta)
EMAIL_FROM="administracion@reportemedico.com"   # remitente verificado (dominio autenticado)
# En DEV apuntá a localhost para que los links de los emails abran tu front local
FRONTEND_URL="https://reportemedico.com"
ADMIN_EMAIL="administracion@reportemedico.com"  # destino de avisos al admin (V2)

# V2 — Guía Médica
# Mismo valor que REVALIDATE_SECRET del frontend: el backend lo usa para
# regenerar páginas ISR (perfiles, programáticas) al aprobar/editar médicos
REVALIDATE_SECRET=""

# Auth0 (V2) — el backend valida los access tokens de los médicos contra el
# JWKS del tenant. Mismos valores que el front (sin client secret).
AUTH0_ISSUER_BASE_URL="https://TU-DOMINIO.us.auth0.com"
AUTH0_AUDIENCE="https://api.reportemedico.com"