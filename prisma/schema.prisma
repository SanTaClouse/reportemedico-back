generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────
// USUARIOS (solo ADMIN en V1 — extensible a futuro)
// ─────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // bcrypt hash
  role      Role     @default(ADMIN)
  name      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  // DOCTOR    <- V2
  // MODERATOR <- V2
}

// ─────────────────────────────────────────────────
// TABLA CENTRAL: ARTICLES
// Unifica noticias y artículos médicos
// ─────────────────────────────────────────────────

model Article {
  id             String        @id @default(uuid())
  type           ArticleType
  title          String
  slug           String        @unique
  excerpt        String?
  content        String

  featuredImage  String?

  authorName     String        @default("Reporte Médico")
  authorPhoto    String?
  authorEmail    String?

  status         ArticleStatus @default(DRAFT)
  relevance      Int?

  viewsCount     Int           @default(0)

  publishedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tags           ArticleTag[]
  media          ArticleMedia[]
  seoMetadata    SeoMetadata?
  relatedFrom    RelatedArticle[] @relation("ArticleFrom")
  relatedTo      RelatedArticle[] @relation("ArticleTo")
  sources              ArticleSource[]
  suggestedSpecialties String[]        @default([])
  search_vector        Unsupported("tsvector")?

  @@index([slug])
  @@index([status, type])
  @@index([relevance, status])
  @@index([publishedAt])
}

enum ArticleType {
  NEWS
  MEDICAL_ARTICLE
}

enum ArticleStatus {
  DRAFT
  PENDING
  PUBLISHED
  ARCHIVED
}

// ─────────────────────────────────────────────────
// TAGS
// ─────────────────────────────────────────────────

model Tag {
  id          String          @id @default(uuid())
  name        String          @unique
  slug        String          @unique
  description String?
  createdAt   DateTime        @default(now())

  articles    ArticleTag[]
  subscribers SubscriberTag[]

  @@index([slug])
}

model ArticleTag {
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
}

// ─────────────────────────────────────────────────
// SUSCRIPTORES
// ─────────────────────────────────────────────────

model Subscriber {
  id        String           @id @default(uuid())
  email     String           @unique
  name      String?
  source    SubscriberSource
  createdAt DateTime         @default(now())

  tags      SubscriberTag[]

  @@index([source])
  @@index([createdAt])
}

enum SubscriberSource {
  ARTICLE_SUBMISSION
  NEWSLETTER_SIGNUP
}

model SubscriberTag {
  subscriberId String
  tagId        String
  subscriber   Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  tag          Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([subscriberId, tagId])
}

// ─────────────────────────────────────────────────
// MEDIA (Cloudinary)
// ─────────────────────────────────────────────────

model Media {
  id        String   @id @default(uuid())
  url       String
  publicId  String   @unique
  altText   String?
  width     Int?
  height    Int?
  fileHash  String?  @unique  // SHA-256 del buffer — previene subidas duplicadas
  folder    String?            // Contexto: Reporte-Medico/Media, Noticias, Ads…
  createdAt DateTime @default(now())

  articles  ArticleMedia[]
}

model ArticleMedia {
  articleId String
  mediaId   String
  position  Int     @default(0)
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  media     Media   @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@id([articleId, mediaId])
}

// ─────────────────────────────────────────────────
// SEO METADATA (1:1 con Article)
// ─────────────────────────────────────────────────

model SeoMetadata {
  id              String  @id @default(uuid())
  articleId       String  @unique
  article         Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  metaTitle       String?
  metaDescription String?
  ogImage         String?
}

// ─────────────────────────────────────────────────
// ARTÍCULOS RELACIONADOS (self-referential)
// ─────────────────────────────────────────────────

model RelatedArticle {
  articleId        String
  relatedArticleId String
  article          Article @relation("ArticleFrom", fields: [articleId], references: [id], onDelete: Cascade)
  relatedArticle   Article @relation("ArticleTo", fields: [relatedArticleId], references: [id], onDelete: Cascade)

  @@id([articleId, relatedArticleId])
}

// ─────────────────────────────────────────────────
// FUENTES CIENTÍFICAS
// ─────────────────────────────────────────────────

model ArticleSource {
  id        String  @id @default(uuid())
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  title     String
  url       String?
  order     Int     @default(0)

  @@index([articleId])
}

// ─────────────────────────────────────────────────
// EDICIONES IMPRESAS
// ─────────────────────────────────────────────────

model PrintEdition {
  id            String   @id @default(uuid())
  editionNumber Int      @unique
  title         String
  coverImage    String
  issuuUrl      String
  publishedAt   DateTime
  isVisible     Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@index([isVisible])
}

// ─────────────────────────────────────────────────
// EPISODIOS DE PODCAST (YouTube)
// ─────────────────────────────────────────────────

model PodcastEpisode {
  id           String   @id @default(uuid())
  title        String
  description  String?
  youtubeId    String
  thumbnailUrl String?
  isVisible    Boolean  @default(true)
  order        Int      @default(0)
  publishedAt  DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([isVisible, order])
}

// ─────────────────────────────────────────────────
// PUBLICIDAD — SLOTS Y ANUNCIOS
// ─────────────────────────────────────────────────

enum AdSlotDisplayMode {
  SINGLE  // Un anuncio aleatorio por visita
  STRIP   // Todos los anuncios en marquee continuo
}

model AdSlot {
  id          String             @id @default(uuid())
  name        String             @unique  // ej: "banner_home_1"
  description String?
  isActive    Boolean            @default(true)
  displayMode AdSlotDisplayMode  @default(SINGLE)
  assignments AdSlotAssignment[]
}

model Ad {
  id          String             @id @default(uuid())
  title       String
  imageUrl    String
  link        String
  isActive    Boolean            @default(true)
  clicks      Int                @default(0)
  impressions Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  assignments AdSlotAssignment[]
}

/// Tabla de unión Ad ↔ AdSlot — un anuncio puede estar en varios banners
model AdSlotAssignment {
  id     String @id @default(uuid())
  adId   String
  slotId String
  order  Int    @default(0)
  ad     Ad     @relation(fields: [adId], references: [id], onDelete: Cascade)
  slot   AdSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)

  @@unique([adId, slotId])
  @@index([slotId, order])
}

// ─────────────────────────────────────────────────
// CONSEJO MÉDICO EDITORIAL
// ─────────────────────────────────────────────────

model CouncilMember {
  id          String   @id @default(uuid())
  name        String
  role        String
  photo       String?
  linkedinUrl String?
  isFeatured  Boolean  @default(false)
  isVisible   Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isVisible, order])
}
